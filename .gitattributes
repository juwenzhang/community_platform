# 强制 LF 行尾（跨平台一致性）
* text=auto eol=lf

# 明确文本文件
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.proto text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.mdc text eol=lf
*.proto text eol=lf

# Rust
Cargo.lock text eol=lf -diff

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock 文件合并冲突时直接覆盖
pnpm-lock.yaml merge=ours
