{
  "name": "@luhanxin/md-parser-theme",
  "version": "0.2.0",
  "description": "Default theme for md-parser — CSS styles for markdown-body, code blocks, containers, mermaid, KaTeX",
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./index.css": "./dist/index.css"
