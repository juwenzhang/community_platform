{
  "name": "@luhanxin/md-parser-react",
  "version": "0.1.0",
  "description": "React components for Markdown rendering with unified ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "markdown",
    "react",
    "renderer",
    "unified",
    "shiki",
    "mermaid"
  ],
  "author": "luhanxin",
  "license": "MIT",
  "peerDependencies": {
    "mermaid": "^10.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@luhanxin/md-parser-core": "workspace:*",
    "dompurify": "3.3.3"
  },
  "devDependencies": {
    "@types/dompurify": "3.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "mermaid": "11.14.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.0.0"
  }
}
