{
  "name": "@luhanxin/dev-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo 开发态工具：Vite 插件、服务发现、端口注册",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./src/vite/index.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
