{
  "name": "@luhanxin/md-parser-vue",
  "version": "0.1.0",
  "description": "Vue 3 components for Markdown rendering with unified ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "markdown",
    "vue",
    "vue3",
    "renderer",
    "unified",
    "shiki",
    "mermaid"
  ],
  "author": "luhanxin",
  "license": "MIT",
  "peerDependencies": {
    "mermaid": "^10.0.0",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@luhanxin/md-parser-core": "workspace:*",
    "dompurify": "3.3.3"
  },
  "devDependencies": {
    "@types/dompurify": "3.2.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "mermaid": "11.14.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
