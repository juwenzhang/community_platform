# ============================================
# Luhanxin Community Platform - Docker 环境变量
# 复制为 .env 后修改
# ============================================

# ---------- PostgreSQL ----------
POSTGRES_USER=luhanxin
POSTGRES_PASSWORD=luhanxin_dev_2024
POSTGRES_DB=luhanxin_community
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PASSWORD=redis_dev_2024
REDIS_PORT=6379

# ---------- Meilisearch ----------
MEILI_MASTER_KEY=meili_dev_master_key_2024
MEILI_PORT=7700

# ---------- 后端服务端口 ----------
GATEWAY_PORT=8000
SVC_USER_PORT=50051
SVC_CONTENT_PORT=50052
SVC_SOCIAL_PORT=50053
SVC_NOTIFICATION_PORT=50054
SVC_SEARCH_PORT=50055

# ---------- 连接字符串（供后端服务 + Makefile 使用）----------
# ⚠️ 不能用 ${VAR} 引用，因为 Makefile include 不支持 shell 变量替换
DATABASE_URL=postgres://luhanxin:luhanxin_dev_2024@localhost:5432/luhanxin_community
REDIS_URL=redis://:redis_dev_2024@localhost:6379
MEILI_URL=http://localhost:7700

# ---------- JWT 认证 ----------
JWT_SECRET=dev_jwt_secret_luhanxin_2024_change_in_production
JWT_EXPIRY_HOURS=168
