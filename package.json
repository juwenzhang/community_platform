{
  "name": "@luhanxin/community-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Luhanxin Community Platform - Monorepo",
  "scripts": {
    "prepare": "husky",
    "init:playwright": "pnpm exec playwright install --with-deps",
    "dev": "bash scripts/dev.sh",
    "dev:main": "pnpm --filter @luhanxin/main dev",
    "dev:feed": "pnpm --filter @luhanxin/feed dev",
    "build": "pnpm -r build",
    "build:main": "pnpm --filter @luhanxin/main build",
    "build:feed": "pnpm --filter @luhanxin/feed build",
    "build:preview": "bash scripts/build-preview.sh",
    "preview": "bash scripts/build-preview.sh && pnpm --filter @luhanxin/main preview",
    "typecheck": "pnpm -r --parallel exec tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "proto": "cd proto && buf generate",
    "proto:lint": "cd proto && buf lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "clean:all": "rm -rf node_modules apps/*/node_modules packages/*/node_modules pnpm-lock.yaml"
  },
  "devDependencies": {
    "@ant-design/icons": "6.1.0",
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "antd": "^5.22.0",
    "husky": "9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "16.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "4.1.0",
    "zustand": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
